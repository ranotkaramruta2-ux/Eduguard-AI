# Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=5001

# Database Configuration
MONGO_URI=mongodb://localhost:27017/student_dropout_prediction

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production_use_strong_random_string
JWT_EXPIRE=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Twilio Configuration (Optional - for SMS/WhatsApp notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ML Model API Configuration
ML_API_URL=http://localhost:5000/predict
USE_FALLBACK_PREDICTION=true

# File Upload Configuration
MAX_FILE_SIZE=10485760
